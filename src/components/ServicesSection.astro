---
// ServicesSection.astro — "Qué puedo hacer por tu producto"
// Layout: título grande + dos columnas (párrafo izq | lista bala der)

const items: string[] = [
  "Investigación y análisis de usuarios",
  "Arquitectura de la información y flujos",
  "Diseño UI y design system",
  "Prototipos interactivos",
  "Testing y mejora continua",
  "Diseño responsive para web y mobile",
];
---

<section
  class="w-full px-6 md:px-12 lg:px-[80px] desktop:px-[160px] pb-5"
  aria-labelledby="services-heading"
>
  <div class="py-12 md:py-20 border-t border-gray-200">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-24 items-start">

      <!-- Columna izquierda -->
      <div class="lg:sticky lg:top-28">
        <h2
          id="experience-heading"
          class="font-heading text-5xl sm:text-7xl xl:text-[5.6rem] desktop:text-8xl text-gray-900 mb-10 leading-none"
        >
          Mi enfoque
        </h2>

        <p class="font-body text-base md:text-lg lg:text-xl text-gray-600 leading-relaxed max-w-xl">
          Combino estrategia, diseño y análisis para crear productos digitales que no solo se ven bien, sino que funcionan.
        </p>
        <p class="font-body text-base md:text-lg lg:text-xl text-gray-600 leading-relaxed max-w-xl">Transformo productoa en una experiencias que convierten.</p>
      </div>

      <!-- Columna derecha -->
      <div>
        <ul class="flex flex-col gap-4" role="list">
          {items.map((item) => (
            <li class="font-body text-base md:text-xl flex items-center gap-3 text-gray-800">
              <span class="shrink-0 w-3 h-3 bg-accent" aria-hidden="true"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>

    </div>

  </div>
</section>

