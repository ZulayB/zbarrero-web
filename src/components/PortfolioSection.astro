---
// PortfolioSection.astro
// 3 columnas, aspect-ratios variados, títulos solo en hover overlay

interface Project {
  title: string;
  category: string;
  imgSrc: string;
  href: string;
  // Tailwind aspect-ratio class → crea alturas distintas por card
  aspect: "aspect-[3/4]" | "aspect-[4/3]" | "aspect-square" | "aspect-[2/3]";
}

const projects: Project[] = [
  {
    title: "World League Live",
       category: "UX / UI / Web / Gaming",
    imgSrc: "images/wll-2025.jpg",
    href: "#",
    aspect: "aspect-[3/4]",          // portrait — columna 1, fila 1
  },
  {
    title: "Melody - La chica del tren",
    category: "UX / UI / Web",
     imgSrc: "images/melody.jpg",
    href: "/proyectos/sedeco-plaquette",
    aspect: "aspect-[4/3]",          // landscape — columna 2, fila 1 (referente: brochure)
  },
  {
    title: "Ultraedge",
    category: "UX / UI / Web",
    imgSrc: "images/ultraedge_bassa.jpg",
    href: "/proyectos/zebral-calendarios",
    aspect: "aspect-[4/3]",          // landscape — columna 3, fila 1
  },
  {
title: "DFG Studio",
    category: "UX / UI / Web",
    imgSrc: "images/DFG.jpg",
    href: "/proyectos/zebral-brand",
    aspect: "aspect-square",         // cuadrado — columna 1, fila 2
  },
  {
     title: "Father.IO",
    category: "UX / UI / Web / Gaming",
    imgSrc: "images/seedingtag01.jpg",
    href: "/proyectos/no-contest",
    aspect: "aspect-[3/4]",          // portrait — columna 2, fila 2
  },
  {
    title: "Father.IO",
    category: "UX / UI / Web / Gaming",
    imgSrc: "images/fatherio_2025.jpg",
    href: "/proyectos/sedeco-social",
    aspect: "aspect-[4/3]",          // landscape — columna 3, fila 2
  },
];
---

<section class="bg-white py-0 lg:py-14" id="trabajos">
  <div class="w-full px-6 md:px-12 lg:px-[80px] desktop:px-[160px]">

    <!-- ── Header ── -->
    <div class="mb-14 lg:mb-20 flex items-end justify-between gap-8">
<h2 class="font-heading text-6xl sm:text-7xl xl:text-[5.6rem] desktop:text-9xl text-gray-900 leading-none shrink-0">
  Portafolio
</h2>

      <p class="hidden lg:block font-body text-md text-gray-500 leading-tight max-w-[300px] text-right pb-1">
        Una recopilación de proyectos que muestran mi experiencia en experiencias de usuario y soluciones visuales.
      </p>

    </div>

    <!-- ── Masonry 3 columnas (columns) — sin espacios vacíos ── -->
    <div class="columns-1 sm:columns-2 lg:columns-3 gap-4">

      {projects.map((project) => (
        <a
          href={project.href}
          class="group relative overflow-hidden bg-gray-100 block mb-4 break-inside-avoid focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
          aria-label={project.title}
        >
          <!-- Imagen con aspect-ratio variable -->
          <div class:list={[project.aspect, "overflow-hidden w-full"]}>
            <img
              src={project.imgSrc}
              alt={project.title}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-105"
            />
          </div>

          <!-- Overlay: oculto por defecto, visible en hover -->
          <div class="absolute inset-0 flex flex-col justify-end
                      bg-gradient-to-t from-gray-950/80 via-gray-900/30 to-transparent
                      opacity-0 group-hover:opacity-100
                      transition-opacity duration-400 ease-in-out">
            <div class="p-5 translate-y-3 group-hover:translate-y-0 transition-transform duration-400 ease-out">
              <p class="font-body text-[10px] font-semibold text-accent uppercase tracking-[0.22em] mb-1">
                {project.category}
              </p>
              <h3 class="font-body text-base md:text-lg font-semibold text-white leading-snug">
                {project.title}
              </h3>
              <span class="inline-flex items-center gap-1 mt-3 font-body text-xs text-white/70 uppercase tracking-widest">
                Ver proyecto
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2.5"
                  stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}

    </div>

    <!-- ── CTA ── -->
    <div class="mt-14 flex justify-center">
      <a
        href="#contacto"
        class="group inline-flex items-center gap-3 font-body text-sm font-semibold text-gray-900 uppercase tracking-widest border-b-2 border-accent pb-1 hover:text-accent transition-colors duration-200"
      >
        Ver todos los proyectos
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          class="transition-transform duration-200 group-hover:translate-x-1">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

  </div>
</section>

