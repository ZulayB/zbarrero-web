---
// Footer.astro
const linkedinUrl = "https://www.linkedin.com/in/tu-perfil"; // ← cambia por tu URL real
---

<footer class="w-full border-t border-gray-200 px-6 md:px-12 lg:px-[80px] desktop:px-[160px] py-10">
  <div class="flex items-center justify-between">

    <!-- Copyright -->
    <p class="font-body text-base text-gray-500">
      © 2026 All rights reserved.
    </p>

    <!-- LinkedIn button -->
    <a
      href={linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 font-body text-sm text-gray-700 border border-gray-300 rounded-full px-4 py-1.5 hover:border-gray-500 hover:text-gray-900 transition-colors duration-200"
      aria-label="LinkedIn"
    >
      <!-- LinkedIn icon -->
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
        fill="currentColor" aria-hidden="true">
        <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5zM.5 8.5H4.5V24H.5V8.5zm7.5 0H12v2.16h.06c.55-1.04 1.9-2.16 3.91-2.16C20.1 8.5 21 11.18 21 15.06V24h-4V15.82c0-1.95-.04-4.47-2.72-4.47-2.73 0-3.15 2.13-3.15 4.33V24H8V8.5z"/>
      </svg>
      Linkedin
    </a>

  </div>
</footer>

