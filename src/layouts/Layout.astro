<style is:global>
  * {
    font-family: "Poppins", sans-serif;
  }
  
  body {
    line-height: 1.6;
  }
  
  /* Smooth scrolling */
  html {
    scroll-behavior: smooth;
  }
  
  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }
  
  ::-webkit-scrollbar-track {
    background: #f1f1f1;
  }
  
  ::-webkit-scrollbar-thumb {
    background: #f59e0b;
    border-radius: 4px;
  }
  
  ::-webkit-scrollbar-thumb:hover {
