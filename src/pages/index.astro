---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Costuras Alicante - Tu taller de confianza">

  <!-- Header -->
  <header id="header" class="bg-transparent shadow-none fixed w-full top-0 z-50 transition-all duration-300">
    <nav class="relative container mx-auto px-4 md:px-6 py-5 md:py-5 flex justify-between items-center">
      <div class="flex items-center">
        <img src="/images/logo_costuras.svg" alt="Costuras Alicante Logo" class="h-[35px] md:h-[50px] mr-4 filter brightness-0 invert transition-all duration-300" id="logo">
      </div>
      
      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center space-x-8">
        <ul class="flex space-x-8">
          <li><a href="#inicio" class="text-white hover:text-yellow-400 transition-all duration-300 font-medium nav-link">Inicio</a></li>
          <li><a href="#servicios" class="text-white hover:text-yellow-400 transition-all duration-300 font-medium nav-link">Servicios</a></li>
          <li><a href="#cursos" class="text-white hover:text-yellow-400 transition-all duration-300 font-medium nav-link">Cursos</a></li>
          <li><a href="#contacto" class="text-white hover:text-yellow-400 transition-all duration-300 font-medium nav-link">Contacto</a></li>
        </ul>
       <div
  class="flex items-center space-x-2 font-medium transition-all duration-300 text-white bg-white/10 px-4 py-1.5 rounded-full text-[20px] border border-white"
  id="phone-desktop"
>
  <i class="fas fa-phone text-yellow-500"></i>
  <span>+34 615 689 300</span>
</div>

      
      <!-- Mobile Menu Button - Comentado temporalmente -->
      <!-- 
      <button class="md:hidden text-white transition-all duration-300" id="mobile-menu-button">
        <div class="w-6 h-6 flex flex-col justify-center space-y-1">
          <div class="w-full h-0.5 bg-current"></div>
          <div class="w-full h-0.5 bg-current"></div>
          <div class="w-full h-0.5 bg-current"></div>
        </div>
      </button>
      -->
    </nav>
  </header>

  <!-- Mobile Contact Fixed Button -->
 <div class="md:hidden fixed bottom-4 left-1/2 transform -translate-x-1/2 z-50">
  <a href="tel:+34615689300"
     class="w-64 bg-yellow-500 text-white px-6 py-3 rounded-full font-semibold shadow-lg hover:bg-yellow-600 transition-all duration-300 flex items-center justify-center space-x-2">
    <span>📞</span>
    <span class="text-xl">+34 615 689 300</span>
  </a>
</div>

  <!-- Hero Section -->
  <section id="inicio" class="relative h-[60vh] md:min-h-screen flex items-center justify-center overflow-hidden" style="background-image: url('/images/hero-image.png'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-gradient-to-br from-yellow-400 to-yellow-600 opacity-25"></div>
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative z-10 text-center text-white px-4 md:px-6 max-w-5xl mx-auto">
      <h1 class="text-3xl md:text-6xl lg:text-8xl font-bold mb-6 md:mb-8 leading-tight pt-8 md:pt-12">Tu taller de costura en Alicante</h1>
      <p class="text-base md:text-2xl lg:text-3xl mb-8 md:mb-12 max-w-3xl mx-auto font-light">Arreglos de ropa, servicio de lavandería y tintorería con calidad y cuidado profesional</p>
      <a href="#servicios" class="inline-block bg-yellow-500 text-white px-6 md:px-8 py-3 md:py-4 rounded-full font-semibold text-sm md:text-lg hover:bg-yellow-600 transition-all duration-300 transform hover:scale-105 shadow-lg">
        Descubre Nuestros Servicios
      </a>
    </div>
  </section>

  <!-- Servicios de Costura -->
  <section id="servicios" class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-16 md:mb-20">
        <h2 class="text-3xl md:text-5xl font-bold mb-6 text-gray-800">Nuestros Servicios de Costura</h2>
        <p class="text-lg md:text-xl text-gray-600 max-w-3xl mx-auto">Ofrecemos servicios profesionales de costura y arreglos con más de 20 años de experiencia</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
        <!-- Ropa de Vestir -->
        <div class="group bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
          <div class="h-48 md:h-64 bg-gradient-to-br from-gray-200 to-gray-300 relative overflow-hidden">
            <img src="/images/ropa-vestir.png" alt="Ropa de vestir" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
            <div class="absolute inset-0 flex items-center justify-center bg-gray-200" style="display: none;">
              <div class="text-4xl md:text-6xl">👔</div>
            </div>
          </div>
          <div class="p-6 md:p-8">
            <h3 class="text-xl md:text-2xl font-bold mb-4 text-gray-800">Ropa de Vestir</h3>
            <p class="text-gray-900 text-lg mb-6 leading-relaxed">Arreglos y ajustes profesionales para prendas de uso diario y formal con acabados perfectos.</p>
            <ul class="text-lg text-gray-900 space-y-2">
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Chaquetas y Americanas</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Pantalones y Vestidos</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Camisas, Blusas y Abrigos</li>
            </ul>
          </div>
        </div>

        <!-- Sastrería -->
        <div class="group bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
          <div class="h-48 md:h-64 bg-gradient-to-br from-yellow-100 to-yellow-200 relative overflow-hidden">
            <img src="/images/sastreria.png" alt="Sastrería" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
            <div class="absolute inset-0 flex items-center justify-center bg-yellow-100" style="display: none;">
              <div class="text-4xl md:text-6xl">🪡</div>
            </div>
          </div>
          <div class="p-6 md:p-8">
            <h3 class="text-xl md:text-2xl font-bold mb-4 text-gray-800">Sastrería y Modificaciones</h3>
            <p class="text-gray-900 text-lg mb-6 leading-relaxed">Servicios especializados para adaptar, transformar o renovar prendas con técnicas tradicionales.</p>
            <ul class="text-lg text-gray-900 space-y-2">
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Arreglos de sastrería</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Ajustes de talla</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Cambios de cierre o botones</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Reparación de costuras</li>
            </ul>
          </div>
        </div>

        <!-- Textiles del Hogar -->
        <div class="group bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 md:col-span-2 lg:col-span-1">
          <div class="h-48 md:h-64 bg-gradient-to-br from-gray-200 to-gray-300 relative overflow-hidden">
            <img src="/images/textiles-hogar.png" alt="Textiles del hogar" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
            <div class="absolute inset-0 flex items-center justify-center bg-gray-200" style="display: none;">
              <div class="text-4xl md:text-6xl">🏠</div>
            </div>
          </div>
          <div class="p-6 md:p-8">
            <h3 class="text-xl md:text-2xl font-bold mb-4 text-gray-800">Textiles para el Hogar</h3>
            <p class="text-gray-900 text-lg mb-6 leading-relaxed">Ajustes, reformas y mantenimiento de elementos textiles del hogar con máxima calidad.</p>
            <ul class="text-lg text-gray-900 space-y-2">
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Cortinas y Mantas</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Fundas (cama, cojines, sofás)</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Edredones</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios de Lavandería -->
  <section class="py-16 md:py-24 bg-gray-50 bg-yellow-500">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 md:gap-16 items-center">
        <div class="order-2 lg:order-1">
          <div class="h-64 md:h-96 bg-gradient-to-br from-blue-100 to-blue-200 rounded-2xl relative overflow-hidden shadow-xl">
            <img src="/images/lavanderia.png" alt="Servicios de lavandería" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
            <div class="absolute inset-0 flex items-center justify-center bg-blue-100" style="display: none;">
              <div class="text-6xl md:text-8xl"><img src="/images/lavenderia.png" alt="Textiles del hogar" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"></div>
            </div>
          </div>
        </div>
        
        <div class="order-1 lg:order-2">
          <h2 class="text-3xl md:text-5xl font-bold mb-6 md:mb-8 text-white">Servicios de Lavandería y Tintorería</h2>
          <p class="text-lg md:text-xl text-gray-600 mb-8 md:mb-12 leading-relaxed text-white">Cuidado profesional para todas tus prendas con tecnología avanzada y productos de calidad premium.</p>
          
          <div class="space-y-6 md:space-y-8">
            <div class="flex items-start space-x-4 md:space-x-6">
              <div class="flex-shrink-0 w-12 h-12 md:w-16 md:h-16 bg-yellow-100 rounded-full flex items-center justify-center">
                <span class="text-xl md:text-2xl">🧽</span>
              </div>
              <div>
                <h3 class="text-xl md:text-2xl font-semibold mb-2 md:mb-3 text-white">Lavado en Seco</h3>
                <p class="text-gray-600 leading-relaxed text-white">Cuidado especializado para prendas delicadas utilizando solventes profesionales que preservan la calidad de los tejidos.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4 md:space-x-6">
              <div class="flex-shrink-0 w-12 h-12 md:w-16 md:h-16 bg-blue-100 rounded-full flex items-center justify-center">
                <span class="text-xl md:text-2xl">💧</span>
              </div>
              <div>
                <h3 class="text-xl md:text-2xl font-semibold mb-2 md:mb-3 text-white">Lavado Normal</h3>
                <p class="text-gray-600 leading-relaxed text-white">Limpieza profunda y efectiva para prendas de uso diario con detergentes ecológicos y procesos optimizados.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4 md:space-x-6">
              <div class="flex-shrink-0 w-12 h-12 md:w-16 md:h-16 bg-green-100 rounded-full flex items-center justify-center">
                <span class="text-xl md:text-2xl">👕</span>
              </div>
              <div>
                <h3 class="text-xl md:text-2xl font-semibold mb-2 md:mb-3 text-white">Planchado Profesional</h3>
                <p class="text-gray-600 leading-relaxed text-white">Acabado perfecto con técnicas profesionales que garantizan un resultado impecable en todas tus prendas.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cursos Personalizados -->
  <section id="cursos" class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 md:gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold mb-6 md:mb-8 text-gray-800">Cursos Personalizados de Costura</h2>
          <p class="text-lg md:text-xl text-gray-600 mb-6 md:mb-8 leading-relaxed">Aprende costura con nuestros cursos personalizados y adquiere las habilidades para hacer arreglos como ajustar camisas o entubar pantalones, y también para confeccionar tus propias prendas desde cero.</p>
          
          <div class="space-y-4 md:space-y-6 mb-8 md:mb-10">
            <div class="flex items-center space-x-4">
              <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
              <span class="text-base md:text-lg text-gray-700">Clases individuales y grupales</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
              <span class="text-base md:text-lg text-gray-700">Horarios flexibles adaptados a ti</span>
            </div>
          </div>
          
          <a href="#contacto" class="inline-block bg-yellow-500 text-white px-6 md:px-8 py-3 md:py-4 rounded-full font-semibold text-base md:text-lg hover:bg-yellow-600 transition-all duration-300 transform hover:scale-105 shadow-lg">
            Más Información
          </a>
        </div>
        
        <div>
          <div class="h-64 md:h-96 bg-gradient-to-br from-purple-100 to-pink-200 rounded-2xl relative overflow-hidden shadow-xl">
            <img src="/images/cursos-costura.png" alt="Cursos de costura" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
            <div class="absolute inset-0 flex items-center justify-center bg-purple-100" style="display: none;">
              <div class="text-6xl md:text-8xl">✂️</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Maps -->
  <section class="w-full h-64 md:h-96">
    <iframe 
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d553.1056794541912!2d-0.48648839283158285!3d38.35273397403062!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd623743047bffff%3A0xeb1f8ba32319732!2sCosturas%20Alicante!5e0!3m2!1sit!2sco!4v1752970799872!5m2!1sit!2sco"
      width="100%" 
      height="100%" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      referrerpolicy="no-referrer-when-downgrade"
      title="Ubicación Costuras Alicante">
    </iframe>
  </section>

  <!-- Footer -->
  <footer id="contacto" class="bg-gray-900 text-white py-12 md:py-16">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16">
        <div>
          <h3 class="text-2xl md:text-3xl font-bold mb-6 md:mb-8 text-yellow-400">Horarios de Atención</h3>
          <div class="space-y-3 md:space-y-4 text-base md:text-lg">
            <div class="flex flex-col md:flex-row md:justify-between md:items-center py-2 md:py-3 border-b border-gray-700">
              <span class="font-medium">Lunes - Viernes</span>
              <span class="text-yellow-400 text-sm md:text-base">9:00 - 14:00 / 17:00 - 20:00</span>
            </div>
            <div class="flex flex-col md:flex-row md:justify-between md:items-center py-2 md:py-3 border-b border-gray-700">
              <span class="font-medium">Sábados</span>
              <span class="text-yellow-400 text-sm md:text-base">9:00 - 14:00</span>
            </div>
            <div class="flex flex-col md:flex-row md:justify-between md:items-center py-2 md:py-3 border-b border-gray-700">
              <span class="font-medium">Domingos y Festivos</span>
              <span class="text-red-400 text-sm md:text-base">Cerrado</span>
            </div>
          </div>
        </div>
        
        <div class="grid grid-cols-2 gap-6 md:gap-8">
          <!-- Dónde estamos -->
          <div class="w-full">
            <!-- Título principal -->
            <h3 class="w-full text-2xl md:text-3xl font-bold mb-6 md:mb-8 text-yellow-400">
              Contáctanos
            </h3>
            <!-- Contenedor en columnas (stack en mobile, lado a lado en desktop) -->
            <div class="flex flex-col md:flex-row gap-8">              
              <!-- Columna 1: Dónde estamos -->
              <div class="flex-1 space-y-4">
                <h4 class="text-xl font-bold text-white-400">Dónde estamos</h4>
                <div class="flex items-start space-x-3">
                  <div class="text-yellow-400 mt-1">📍</div>
                  <div>
                    <p class="font-medium">Avenida Alcoy Nº 9</p>
                    <p class="text-gray-300 text-sm md:text-base">03010 Alicante, España</p>
                  </div>
                </div>
                <div class="flex items-center space-x-3">
                  <div class="text-yellow-400">📞</div>
                  <a href="tel:+34615689300" class="hover:text-yellow-400 transition-colors text-sm md:text-base">
                    +34 615 689 300
                  </a>
                </div>
                <div class="flex items-center space-x-3">
                  <div class="text-yellow-400">✉️</div>
                  <a href="mailto:info@costurasalicante.com" class="hover:text-yellow-400 transition-colors text-sm md:text-base">
                    info@costurasalicante.com
                  </a>
                </div>
              </div>
              <!-- Columna 2: Síguenos -->
              <div class="flex-1">
                <h4 class="text-xl font-bold text-white mb-4">Síguenos</h4>
                <div class="flex space-x-4">
                  <a href="https://web.facebook.com/costurasalicanteoficial" target="_blank" class="w-12 h-12 bg-yellow-500 rounded-full flex items-center justify-center hover:bg-yellow-600 transition-colors">
                    <i class="fab fa-facebook-f text-white text-lg"></i>
                  </a>
                  <a href="https://www.instagram.com/costurasalicanteoficial/" target="_blank" class="w-12 h-12 bg-yellow-500 rounded-full flex items-center justify-center hover:bg-yellow-600 transition-colors">
                    <i class="fab fa-instagram text-white text-lg"></i>
                  </a>
                </div>
              </div>
            </div>
          </div>  
        </div>
      </div>
      
      <div class="border-t border-gray-700 mt-8 md:mt-12 pt-6 md:pt-8 text-center">
        <p class="text-gray-400 text-sm md:text-base">&copy; 2024 Costuras Alicante. Todos los derechos reservados. | Diseñado con ❤️ en Alicante</p>
      </div>
    </div>
  </footer>

</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
  .min-h-screen {
    min-height: 90vh;
  }
</style>

<script>
  // Header scroll behavior
  window.addEventListener('scroll', () => {
    const header = document.getElementById('header');
    const logo = document.getElementById('logo');
    const navLinks = document.querySelectorAll('.nav-link');
    const phoneDesktop = document.getElementById('phone-desktop');
    
    if (!header) return;

    if (window.scrollY > 50) {
      // Scrolled - white background, dark text
      header.classList.remove('bg-transparent', 'shadow-none');
      header.classList.add('bg-white/95', 'backdrop-blur-sm', 'shadow-lg');
      
      // Logo to dark
      if (logo) {
        logo.classList.remove('brightness-0', 'invert');
      }
      
      // Nav links to dark
      navLinks.forEach(link => {
        link.classList.remove('text-white');
        link.classList.add('text-gray-700');
      });
      
      // Phone number to dark
      if (phoneDesktop) {
        phoneDesktop.classList.remove('text-white');
        phoneDesktop.classList.add('text-gray-700');
      }
    } else {
      // Top of page - transparent background, white text
      header.classList.remove('bg-white/95', 'backdrop-blur-sm', 'shadow-lg');
      header.classList.add('bg-transparent', 'shadow-none');
      
      // Logo to white
      if (logo) {
        logo.classList.add('brightness-0', 'invert');
      }
      
      // Nav links to white
      navLinks.forEach(link => {
        link.classList.remove('text-gray-700');
        link.classList.add('text-white');
      });
      
      // Phone number to white
      if (phoneDesktop) {
        phoneDesktop.classList.remove('text-gray-700');
        phoneDesktop.classList.add('text-white');
      }
    }
  });
</script>

