---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Costuras Alicante - Tu taller de confianza">

  <!-- Header -->
  <header id="header" class="bg-transparent shadow-none fixed w-full top-0 z-50 transition-all duration-300">
    <nav class="relative px-4 md:px-8 lg:px-16 xl:px-24 py-5 flex justify-between items-center">

      <div class="flex items-center">
        <img src="/images/logo_costuras.svg" alt="Costuras Alicante" class="h-[30px] md:h-[40px] lg:h-[45px] mr-4 filter brightness-0 invert transition-all duration-300" id="logo">
      </div>
      
      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center space-x-8">
        <ul class="flex space-x-8">
          <li><a href="#inicio" class="text-white hover:text-yellow-400 transition-all duration-300 font-medium nav-link">Inicio</a></li>
          <li><a href="#servicios" class="text-white hover:text-yellow-400 transition-all duration-300 font-medium nav-link">Servicios</a></li>
          <li><a href="#cursos" class="text-white hover:text-yellow-400 transition-all duration-300 font-medium nav-link">Cursos</a></li>
          <li><a href="#contacto" class="text-white hover:text-yellow-400 transition-all duration-300 font-medium nav-link">Contacto</a></li>
        </ul>
        <div class="hidden lg:flex items-center space-x-2 font-medium transition-all duration-300 text-white bg-white/10 px-4 py-1.5 rounded-full text-[20px] border border-white" id="phone-desktop">  <i class="fas fa-phone text-yellow-500"></i>  <span>+34 615 689 300</span>
        </div> 
      </div>
    </nav>
  </header>

  <!-- Mobile Contact Fixed Button -->
 <div class="lg:hidden fixed bottom-4 left-1/2 transform -translate-x-1/2 z-50">
  <a href="tel:+34615689300"
     class="w-64 bg-yellow-500 text-gray-800 px-6 py-3 rounded-full font-semibold shadow-lg hover:bg-yellow-600 transition-all duration-300 flex items-center justify-center space-x-2">
    <i class="fas fa-phone text-gray-800"></i>
    <span class="text-xl">+34 615 689 300</span>
  </a>
</div>

  <!-- Hero Section con títulos responsive -->
 <section id="inicio"
   class="relative h-[69vh] sm:min-h-[75vh] lg:min-h-[95vh] n2xl:min-h-[90vh] flex items-center justify-center overflow-hidden"
  style="background-image: url('/images/hero-image.png'); background-size: cover; background-position: center;">
  
  <div class="absolute inset-0 bg-black/45"></div>

  <div class="relative z-10 text-center text-white px-5 md:px-8 max-w-5xl xl:max-w-6xl mx-auto">
<h2 class="text-[1.625rem] sm:text-[1.95rem] md:text-[2.6rem] lg:text-[42px] xl:text-[50px] 2xl:text-[67px] font-bold mb-6 md:mb-8 leading-[1.25] pt-8 md:pt-12" data-astro-cid-j7pv25f6="">
 Arreglos de ropa, lavandería y tintorería en Alicante.
</h2>

<div class="px-6 sm:px-0">
  <h1 class="text-[1.1rem] sm:text-lg md:text-xl lg:text-2xl xl:text-3xl mb-6 font-light leading-[1.5]">
Más de 20 años de experiencia en arreglos de ropa casual, formal y de sastrería. También ofrecemos lavandería y tintorería con atención personalizada.

  </h1>
</div>
  <a href="#servicios" class="inline-block bg-yellow-500 text-white px-4 sm:px-6 md:px-8 py-2 sm:py-3 md:py-4 rounded-full font-semibold text-sm sm:text-base md:text-lg xl:scale-90 hover:bg-yellow-600 transition-all duration-300 transform hover:scale-105 shadow-lg">
    Descubre Nuestros Servicios
  </a>
</div>

    <!-- Scroll Down Arrow -->
    <a href="#servicios" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce" aria-label="Scroll down">
      <img src="/images/arrow.svg" alt="Scroll down" class="w-10 h-10 md:w-12 md:h-12 lg:w-14 lg:h-14">
    </a>
</section>


  <!-- Servicios de Costura con títulos responsive -->
  <section id="servicios" class="pt-[8px] md:pt-[8px] bg-white">
    <div class="w-full">
      <hr class="border-dashed border-yellow-400 w-full" style="border-top-width: 2px;">
    </div>
    <div class="container mx-auto px-4 sm:px-6 py-12 sm:py-16 md:py-24">
      <div class="text-center mb-12 sm:mb-16 md:mb-20">
         <h2 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-bold mb-6 text-gray-800">Nuestros Servicios de Costura</h2>
     
        <p class="text-sm sm:text-base md:text-lg lg:text-xl text-gray-600 max-w-3xl mx-auto">Ofrecemos servicios profesionales de costura y arreglos, respaldados por más de 20 años de experiencia, dedicación y compromiso con la calidad en cada prenda.</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
        <!-- Ropa de Vestir -->
        <div class="group bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
          <div class="h-48 md:h-64 bg-gradient-to-br from-gray-200 to-gray-300 relative overflow-hidden">
            <img src="/images/ropa-vestir.png" alt="Arreglos y ajustes de ropa de vestir en Alicante - Costuras profesionales" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
            <div class="absolute inset-0 flex items-center justify-center bg-gray-200" style="display: none;">              
            </div>
          </div>
          <div class="p-6 md:p-8">
            <h3 class="text-lg md:text-2xl font-bold mb-4 text-gray-800">Ropa de Vestir</h3>
            <p class="text-base md:text-lg text-gray-900 mb-6 leading-relaxed">Arreglos y ajustes profesionales para prendas de uso diario y formal con acabados perfectos.</p>
            <ul class="text-base md:text-lg text-gray-900 space-y-2">
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Chaquetas y Americanas</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Pantalones y Vestidos</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Camisas, Blusas y Abrigos</li>
            </ul>
          </div>
        </div>

        <!-- Sastrería -->
        <div class="group bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
          <div class="h-48 md:h-64 bg-gradient-to-br from-yellow-100 to-yellow-200 relative overflow-hidden">
            <img src="/images/sastreria.png" alt="Servicios de sastrería en Alicante - Trajes y ropa formal" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
            <div class="absolute inset-0 flex items-center justify-center bg-yellow-100" style="display: none;">             
            </div>
          </div>
          <div class="p-6 md:p-8">
            <h3 class="text-lg md:text-2xl font-bold mb-4 text-gray-800">Sastrería y Modificaciones</h3>
            <p class="text-base md:text-lg text-gray-900 mb-6 leading-relaxed">Servicios especializados para adaptar, transformar o renovar prendas con técnicas tradicionales.</p>
            <ul class="text-base md:text-lg text-gray-900 space-y-2">
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Arreglos de sastrería</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Ajustes de talla</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Cambios de cierre o botones</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Reparación de costuras</li>
            </ul>
          </div>
        </div>

        <!-- Textiles del Hogar -->
        <div class="group bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 md:col-span-2 lg:col-span-1">
          <div class="h-48 md:h-64 bg-gradient-to-br from-gray-200 to-gray-300 relative overflow-hidden">
            <img src="/images/textiles-hogar.png" alt="Arreglos de textiles del hogar - Cortinas, fundas y edredones en Alicante" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
            <div class="absolute inset-0 flex items-center justify-center bg-gray-200" style="display: none;">
             </div>
          </div>
          <div class="p-6 md:p-8">
            <h3 class="text-lg md:text-2xl font-bold mb-4 text-gray-800">Textiles para el Hogar</h3>
            <p class="text-base md:text-lg text-gray-900 mb-6 leading-relaxed">Ajustes, reformas y mantenimiento de elementos textiles del hogar con máxima calidad.</p>
            <ul class="text-base md:text-lg text-gray-900 space-y-2">
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Cortinas y Mantas</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Fundas (cama, cojines, sofás)</li>
              <li class="flex items-center"><span class="w-2 h-2 bg-yellow-400 rounded-full mr-3"></span>Edredones</li>
            </ul>
          </div>
        </div>
    </div>   
  </div> 
  <div class="w-full mb-[6px]">
    <hr class="border-dashed border-yellow-400 w-full" style="border-top-width: 2px;" >
  </div>
  </section>

  <!-- Servicios de Lavandería -->
  <section class="relative pt-[8px] md:pt-[8px] bg-white bg-yellow-500">
      <div class="w-full">
    <hr class="border-t-4 border-dashed border-white w-full" style="border-top-width: 2px;">
  </div> 
  
    <div class="container mx-auto px-6 py-16 md:py-24">
      <div class="grid lg:grid-cols-2 gap-12 md:gap-16 items-center">
        <div class="order-2 lg:order-1">
  <div class="h-[70] md:h-[460px] bg-gradient-to-br from-blue-100 to-blue-200 rounded-2xl relative overflow-hidden shadow-xl">
    <img src="/images/lavenderia.png" alt="Servicio de lavandería y tintorería profesional en Alicante" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
    <div class="absolute inset-0 flex items-center justify-center bg-blue-100" style="display: none;">
      <div class="text-6xl md:text-8xl">
        <img src="/images/lavenderia.png" alt="Textiles del hogar" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
      </div>
    </div>
  </div>
</div>

        
        <div class="order-1 lg:order-2">
          <h2 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-bold mb-6 text-white">Servicios de Lavandería y Tintorería</h2>
          <p class="text-base md:text-lg mb-6 leading-relaxed text-white">Cuidado profesional para todas tus prendas con tecnología avanzada y productos de calidad premium.</p>
          
          <div class="space-y-6 md:space-y-8">
            <div class="flex items-start space-x-4 md:space-x-6">
             <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-white rounded-full flex items-center justify-center">
  <span class="text-gray-700 text-base md:text-xl">
    <i class="fa-solid fa-check"></i>
  </span>
</div>


              <div>
                <h3 class="text-xl md:text-2xl lg:text-xl font-semibold mb-2 md:mb-3 text-white">Lavado en Seco</h3>
                <p class="leading-relaxed text-white">Cuidado especializado para prendas delicadas utilizando solventes profesionales que preservan la calidad de los tejidos.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4 md:space-x-6">
               <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-white rounded-full flex items-center justify-center">
  <span class="text-gray-700 text-base md:text-xl">
    <i class="fa-solid fa-check"></i>
  </span>
</div>
              <div>
                <h3 class="text-xl md:text-2xl lg:text-xl font-semibold mb-2 md:mb-3 text-white">Lavado Normal</h3>
                <p class="leading-relaxed text-white">Limpieza profunda y efectiva para prendas de uso diario con detergentes ecológicos y procesos optimizados.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4 md:space-x-6">
              <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-white rounded-full flex items-center justify-center">
  <span class="text-gray-700 text-base md:text-xl">
    <i class="fa-solid fa-check"></i>
  </span>
</div>
              <div>
                <h3 class="text-xl md:text-2xl lg:text-xl font-semibold mb-2 md:mb-3 text-white">Planchado Profesional</h3>
                <p class="leading-relaxed text-white">Acabado perfecto con técnicas profesionales que garantizan un resultado impecable en todas tus prendas.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>  

    <div class="w-full absolute bottom-2">
      <hr class=" border-dashed border-white w-full" style="border-top-width: 2px;">
    </div>
  </section>

 
  <!-- Cursos Personalizados -->
  <section id="cursos" class="pt-[8px] md:pt-[8px] bg-white ">
    <div class="w-full">
    <hr class="border-dashed border-yellow-400 w-full" style="border-top-width: 2px;">
  </div>
    <div class="container mx-auto px-6 py-16 md:py-24">
      <div class="grid lg:grid-cols-2 gap-12 md:gap-16 items-center">
        <div>
          <h2 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-bold mb-6 text-gray-800">Cursos Personalizados de Costura</h2>
          <p class="text-base md:text-lg text-gray-900 mb-6 leading-relaxed">Aprende costura con nuestros cursos personalizados y adquiere las habilidades para hacer arreglos como ajustar camisas o entubar pantalones, y también para confeccionar tus propias prendas desde cero.</p>
          
          <div class="space-y-4 md:space-y-6 mb-8 md:mb-10">
            <div class="flex items-center space-x-4">
              <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
              <span class="text-base md:text-lg text-gray-700">Clases individuales y grupales</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
              <span class="text-base md:text-lg text-gray-700">Horarios flexibles adaptados a ti</span>
            </div>
          </div>
          
          <a href="#contacto" class="inline-block bg-yellow-500 text-white px-6 md:px-8 py-3 md:py-4 rounded-full font-semibold text-base md:text-lg hover:bg-yellow-600 transition-all duration-300 transform hover:scale-105 shadow-lg">
            Más Información
          </a>
        </div>
        
        <div>
          <div class="h-64 md:h-96 bg-gradient-to-br from-purple-100 to-pink-200 rounded-2xl relative overflow-hidden shadow-xl">
            <img src="/images/cursos-costura.png" alt="Cursos personalizados de costura en Alicante - Aprende a coser" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
            <div class="absolute inset-0 flex items-center justify-center bg-purple-100" style="display: none;">             
            </div>
          </div>
        </div>
      </div>
    </div>
      <div class="w-full mb-[8px]">
    <hr class="border-dashed border-yellow-400 w-full" style="border-top-width: 2px;">
  </div>
  </section>

   <!-- Sección de Testimonios - después de Lavandería -->
  <section class="pt-[8px] bg-gray-200">
    <div class="w-full">
      <hr class="border-dashed border-yellow-400 w-full" style="border-top-width: 2px;">
    </div>
    <div class="container mx-auto px-4 sm:px-6 py-12 sm:py-16 md:py-24">
      <!-- Header con calificación promedio -->
      <div class="text-center mb-12 md:mb-16">
        <h2 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-bold mb-4 text-gray-800">Opiniones de nuestros clientes</h2>
        <div class="flex items-center justify-center mb-6">
          <div class="flex items-center space-x-2">
            <span class="text-2xl md:text-3xl font-bold text-gray-800">4.6</span>
            <div class="flex space-x-1">
              <i class="fas fa-star text-yellow-400 text-lg" ></i>
              <i class="fas fa-star text-yellow-400 text-lg"></i>
              <i class="fas fa-star text-yellow-400 text-lg"></i>
              <i class="fas fa-star text-yellow-400 text-lg"></i>
              <i class="fas fa-star text-gray-300 text-lg"></i>
            </div>
            <span class="text-gray-600 text-sm md:text-base">en Google</span>
          </div>
        </div>
      </div>

      <!-- Grid de reseñas -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 mb-12">
        
        <!-- Reseña 1 -->
        <article class="bg-white rounded-lg shadow-md p-6 border-l-4 border-yellow-400">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-blue-500 rounded-full flex items-center justify-center text-white font-bold text-lg">
              M
            </div>
            <div class="ml-3">
              <h4 class="font-semibold text-gray-800">Lina Jaafri Mohib</h4>
              <div class="flex space-x-1 mt-1">
                <i class="fas fa-star text-yellow-400 text-sm"></i>
                <i class="fas fa-star text-yellow-400 text-sm"></i>
                <i class="fas fa-star text-yellow-400 text-sm"></i>
                <i class="fas fa-star text-yellow-400 text-sm"></i>
                <i class="fas fa-star text-yellow-400 text-sm"></i>
              </div>
            </div>
          </div>
          <p class="text-gray-700 text-sm md:text-base leading-relaxed mb-3">
            "Profesionales de verdad. Todo fácil, rápido y bien hecho. Da gusto encontrar sitios así. ¡Volveré sin duda!."
          </p>
          <time class="text-gray-500 text-xs">hace 2 semanas</time>
        </article>

        <!-- Reseña 2 -->
        <article class="bg-white rounded-lg shadow-md p-6 border-l-4 border-yellow-400">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center text-white font-bold text-lg">
              J
            </div>
            <div class="ml-3">
              <h4 class="font-semibold text-gray-800">Evelin Albert</h4>
              <div class="flex space-x-1 mt-1">
                <i class="fas fa-star text-yellow-400 text-sm"></i>
                <i class="fas fa-star text-yellow-400 text-sm"></i>
                <i class="fas fa-star text-yellow-400 text-sm"></i>
                <i class="fas fa-star text-yellow-400 text-sm"></i>
                <i class="fas fa-star text-yellow-400 text-sm"></i>
              </div>
            </div>
          </div>
          <p class="text-gray-700 text-sm md:text-base leading-relaxed mb-3">
            "impecable y de gran calidad. Además, son súper amables y atentas ¡Recomendadísimo!."
          </p>
          <time class="text-gray-500 text-xs">hace 2 semanas</time>
        </article>

        <!-- Reseña 3 -->
        <article class="bg-white rounded-lg shadow-md p-6 border-l-4 border-yellow-400">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-purple-500 rounded-full flex items-center justify-center text-white font-bold text-lg">
              A
            </div>
            <div class="ml-3">
              <h4 class="font-semibold text-gray-800">Ana López</h4>
              <div class="flex space-x-1 mt-1">
                <i class="fas fa-star text-yellow-400 text-sm"></i>
                <i class="fas fa-star text-yellow-400 text-sm"></i>
                <i class="fas fa-star text-yellow-400 text-sm"></i>
                <i class="fas fa-star text-yellow-400 text-sm"></i>
                <i class="fas fa-star text-gray-300 text-sm"></i>
              </div>
            </div>
          </div>
          <p class="text-gray-700 text-sm md:text-base leading-relaxed mb-3">
            "El servicio de lavandería es fantástico. Mis prendas delicadas siempre quedan como nuevas. Personal muy profesional."
          </p>
          <time class="text-gray-500 text-xs">hace 1 mes</time>
        </article>
      </div>

      <!-- Botón ver más reseñas -->
      <div class="text-center">
        <a href="https://www.google.com/maps/place/Costuras+Alicante/@38.3527395,-0.4885854,17z/data=!3m1!4b1!4m6!3m5!1s0xd623743047bffff:0xeb1f8ba32319732!8m2!3d38.3527353!4d-0.4860105!16s%2Fg%2F11ft5c10s5?entry=ttu&g_ep=EgoyMDI1MDcxNi4wIKXMDSoASAFQAw%3D%3D" target="_blank" rel="noopener noreferrer" class="inline-block bg-yellow-500 text-white px-6 md:px-8 py-3 md:py-4 rounded-full font-semibold text-base md:text-lg hover:bg-yellow-600 transition-all duration-300 transform hover:scale-105 shadow-lg">
          <i class="fab fa-google text-lg"></i>
          <span>Ver más reseñas en Google</span>
          <i class="fas fa-external-link-alt text-sm"></i>
        </a>
      </div>
    </div>
    
  </section>

  <!-- Google Maps -->
<section class="w-full h-auto md:h-[32rem] flex flex-col md:flex-row">
  <!-- Mapa: 2/3 -->
  <div class="w-full md:w-2/3 h-80 md:h-full">
    <iframe 
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d553.1056794541912!2d-0.48648839283158285!3d38.35273397403062!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd623743047bffff%3A0xeb1f8ba32319732!2sCosturas%20Alicante!5e0!3m2!1sit!2sco!4v1752970799872!5m2!1sit!2sco"
      width="100%" 
      height="100%" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      referrerpolicy="no-referrer-when-downgrade"
      title="Ubicación Costuras Alicante">
    </iframe>
  </div>

  <!-- Imagen: 1/3 -->
  <div class="w-full md:w-1/3 h-80 md:h-full">
    <img src="/images/costurasalicante.jpg" alt="Costuras Alicante" class="w-full h-full object-cover" />
  </div>
</section>

  <!-- Footer -->
 <footer id="contacto" class="bg-gray-900 text-white pt-[8px] md:pt-[8px]">
  <div class="w-full">
    <hr class="border-dashed border-yellow-400 w-full" style="border-top-width: 2px;">
  </div>
  <div class="container mx-auto px-6 py-16 md:py-24">
